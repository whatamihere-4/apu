# Copy to .env in this directory before running docker compose.
# Keep common settings at the top.
# Put advanced internal settings at the bottom.

# ---------------------- shared stack settings ---------------------
MONOLITH_NETWORK=caddy_net
MEDIA_DOWNLOADS_DIR=./downloads
MEDIA_THUMBS_DIR=./thumbs
CACHE_DIR=./cache

# Optional: scripts/scrape_folders.py (paste browser session headers; no Playwright)
ROOT_FOLDER_LINK=
GOFILE_ACCOUNT_TOKEN=
GOFILE_X_WEBSITE_TOKEN=
GOFILE_USER_AGENT=
GOFILE_ACCEPT_LANGUAGE=

# ---------------------------- upload providers ----------------------------
# Enable one or both backends. When both are on, uploads go to GoFile (full file)
# and Filester (byte-split when >10 GB). If Filester cannot split on disk budget,
# GoFile-only proceeds automatically.
GOFILE_ENABLED=1
FILESTER_ENABLED=0
# Legacy shorthand (overrides defaults above when set):
# UPLOAD_PROVIDER=gofile   → GoFile only
# UPLOAD_PROVIDER=filester → Filester only
# UPLOAD_PROVIDER=dual     → both enabled
# UPLOAD_PROVIDER=gofile
GOFILE_API_KEY=
# Filester (https://filester.me/api-docs)
FILESTER_API_KEY=
# Optional Filester overrides (sane defaults shown).
# FILESTER_BASE_URL=https://u1.filester.me
# FILESTER_SITE_URL=https://filester.me
# Split files larger than this (bytes) before upload; Filester's hard cap is 10 GB.
# Default matches migradora (~9.5 GiB): 10200547328
# FILESTER_MAX_PART_BYTES=10200547328
# How to split oversized Filester uploads:
#   bytes         — raw byte splice (movie.mp4.part001); fastest, ~source+one-part disk; not playable until merged
#   ffmpeg        — one-pass stream-copy (movie.PART1.mp4); ~2× disk during split; each part plays in-browser
#   ffmpeg_slice  — per-part stream-copy (movie.PART1.mp4); ~source+one-part disk; each part plays in-browser
#   optimal       — one-pass ffmpeg when disk allows, else FILESTER_SPLIT_FALLBACK (bytes or ffmpeg_slice)
# FILESTER_SPLIT_MODE=bytes
# When FILESTER_SPLIT_MODE=optimal and one-pass ffmpeg does not fit on disk:
# FILESTER_SPLIT_FALLBACK=bytes
# Studio folder map for GoFile (apu-style {folder_id: name} JSON).
# Lives in cache/gofile-folders.json alongside filester-folders.json.
# GOFILE_FOLDERS_FILE=./cache/gofile-folders.json
# Studio folder map for Filester ({folder_id: name} JSON). Create folders in the
# Filester UI; uploads go into the selected studio folder (split uploads create a subfolder per video).
# FILESTER_FOLDERS_FILE=./cache/filester-folders.json
# Background sync from GET /api/v1/folders (optional):
# FILESTER_FOLDER_SYNC_ENABLED=0
# FILESTER_FOLDER_SYNC_INTERVAL_SEC=3600
# Top-level studio folders only by default (skips split-upload subfolders):
# FILESTER_FOLDER_SYNC_INCLUDE_CHILDREN=0
# Optional ids to exclude from filester-folders.json (auto-appended on split subfolder create):
# FILESTER_FOLDER_BLACKLIST_FILE=./cache/filester-folder-blacklist.json
# Manual sync: python scripts/sync_filester_folders.py
# Disk safeguards for split uploads (peak = source + one part + headroom).
# MIN_FREE_DISK_GB=5
# DISK_BUDGET_GB=0
# MAX_SOURCE_FILE_GB=0
# MAX_SOURCE_FILE_BYTES=0
# AUTO_SKIP_OVERSIZED=1
STASHDB_API_KEY=
STASHDB_GRAPHQL_URL=https://stashdb.org/graphql
# After a StashDB match on upload, submit fingerprints (submitFingerprint). Set 0 to disable writes.
STASHDB_AUTO_CONTRIBUTE=1
THUMBER_ENABLED=1
# Hasher sidecar (apu → hasher-http). When HASHER_ENABLED=0, OSHASH/MD5/PHASH toggles are ignored.
HASHER_ENABLED=1
HASHER_OSHASH_ENABLED=1
HASHER_MD5_ENABLED=1
HASHER_PHASH_ENABLED=1
# hasher-http /v1/hash_stream: PHASH heartbeat interval (sec); MD5 progress emit spacing (bytes).
# HASHER_PHASHER_HEARTBEAT_SEC=1
# HASHER_MD5_PROGRESS_BYTES=8388608
# If ./thumbs/<stem>_thumbs.png already exists for the video basename, skip ffmpeg/thumber (default off).
THUMBER_USE_CACHED_THUMBS=0
THUMBER_HTTP_STREAM=1
THUMBER_LOG_LIMIT=80
# Restore still-queued jobs from cache/pending_queue.json on startup (queue tools). Set 0 to disable.
RESTORE_QUEUE=1

# ------------------------ runtime defaults ------------------------
STASH_REF=v0.27.2
HASHER_PHASH_TIMEOUT_SEC=1800
THUMBER_HTTP_VERBOSE=1
THUMBER_FFMPEG_TIMEOUT_SEC=300
THUMBER_FFMPEG_TIMEOUT_SLOW_SEC=600
# GoonBox image host for BBCode (Direct API + optional server-side auto-upload).
# GOONBOX_BASE_URL=https://goonbox.cr
#
# Auth option A — Bearer token (only if localStorage authToken exists in your browser; often empty):
# GOONBOX_AUTH_TOKEN=
#
# Auth option B — session cookies from DevTools while logged in on goonbox.cr (~2 h TTL):
# GOONBOX_SESSION=
# GOONBOX_XSRF_TOKEN=
# Or paste the full Cookie header (overrides SESSION/XSRF):
# GOONBOX_COOKIE=goonbox_session=...; XSRF-TOKEN=...
#
# Test which works:  python scripts/test_goonbox_auth.py
# Or one-off:        python scripts/test_goonbox_auth.py --session '...' --xsrf '...'
# Optional album for uploads — use the slug from the album URL (e.g. ajDeMe for /a/ajDeMe).
# GOONBOX_ALBUM_ID=ajDeMe
# Auto-upload cover + thumb sheet + SLR GIF after StashDB scene load on /bbcode (default 0).
# GOONBOX_AUTO_UPLOAD=0
# Use [IMG]direct[/IMG] instead of GoonBox wrapped bbcode (default 1).
# GOONBOX_BBCODE_SIMPLE=1

# SLR preview GIF encoding for BBCode (GoonBox max upload is 25 MB / 26214400 bytes).
# SLR_GIF_FPS=12
# SLR_GIF_WIDTH=480
# SLR_GIF_MAX_DURATION=15
# SLR_GIF_MAX_BYTES=26214400
# Optional: max bytes when apu downloads SLR CDN preview MP4 before GIF encode (default 30000000).
# SLR_PREVIEW_MAX_MP4_BYTES=30000000

# Job cards: show basename in download link text instead of full URL (href stays the URL).
# JOB_LINKS_FILENAME_ONLY=0

# Remote OSHASH (/oshash) — optional HTTP timeouts for ranged fetch (defaults 15 / 60 sec)
# OSHASH_REMOTE_CONNECT_TIMEOUT_SEC=15
# OSHASH_REMOTE_READ_TIMEOUT_SEC=60
# Optional: max suffix bytes to Range-fetch when probing MP4 moov for duration beyond head/tail (default 2097152)
# OSHASH_REMOTE_DURATION_PROBE_MAX_BYTES=2097152

# /phash and /remotehash: after a full download for hashing, delete the file under MEDIA_DOWNLOADS_DIR (default 1). Set 0 to keep it for re-hash or draft workflows.
# REMOTE_HASH_DELETE_FILE=1

# Link download (/downloads) — resume on IncompleteRead / connection drops (defaults below).
# DOWNLOAD_CONNECT_TIMEOUT_SEC=30
# DOWNLOAD_READ_TIMEOUT_SEC=900
# DOWNLOAD_RESUME_ATTEMPTS=16
# DOWNLOAD_CHUNK_SIZE=65536

# ------------------ optional resource limits ------------------
# Leave commented/blank to keep current compose defaults.
#
# apu
# MEM_LIMIT=
# CPU_LIMIT=
# PIDS_LIMIT=
#
# hasher-http
# HASHER_MEM_LIMIT=
# HASHER_CPU_LIMIT=
# HASHER_PIDS_LIMIT=
#
# thumber
# THUMBER_MEM_LIMIT=
# THUMBER_CPU_LIMIT=
# THUMBER_PIDS_LIMIT=
#
# thumber-http
# THUMBER_HTTP_PIDS_LIMIT=
#
# splitter-http (these ARE wired in compose; defaults shown)
# SPLITTER_CPU_LIMIT=1.5
# SPLITTER_MEM_LIMIT=1g
# SPLITTER_PIDS_LIMIT=256
# SPLITTER_FFMPEG_TIMEOUT_SEC=7200
# SPLITTER_HTTP_TIMEOUT_SEC=7800

# ---------------- advanced / internal wiring ----------------
# DO NOT EDIT unless you know exactly why.
# These are internal container-to-container endpoints.
HASHER_HTTP_URL=http://hasher-http:8089
THUMBER_HTTP_URL=http://thumber-http:8080
# Splitter sidecar (legacy ffmpeg path; Filester uploads split in-process via byte ranges).
# Leave empty to split in-process inside apu.
# SPLITTER_HTTP_URL=http://splitter-http:8090
# Optional: override path to thumbs generator inside thumber containers (default /usr/local/bin/thumbs).
# THUMBER_THUMBS_SCRIPT=/usr/local/bin/thumbs

# Optional auth for internal POST routes. Keep empty unless enabled in services.
# HASHER_HTTP_TOKEN=
# THUMBER_HTTP_TOKEN=
# SPLITTER_HTTP_TOKEN=
